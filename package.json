{
  "name": "kaisola",
  "productName": "Kaisola",
  "version": "0.1.4",
  "private": true,
  "description": "Kaisola — a Research IDE. Move research from literature → hypotheses → experiments → results → paper, with a human reviewing every transition.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "seed": "node scripts/build-seed.mjs",
    "icon:render": "electron scripts/render-icon.cjs",
    "electron:dev": "concurrently -k \"vite --host 127.0.0.1 --strictPort\" \"wait-on tcp:127.0.0.1:5173 && cross-env KAISOLA_DEV_URL=http://127.0.0.1:5173 electron .\"",
    "electron:dev:tools": "concurrently -k \"vite --host 127.0.0.1 --strictPort\" \"wait-on tcp:127.0.0.1:5173 && cross-env KAISOLA_DEV_URL=http://127.0.0.1:5173 KAISOLA_OPEN_DEVTOOLS=1 electron .\"",
    "electron": "electron .",
    "smoke": "vite build && electron electron/smoke.cjs",
    "shoot": "vite build && electron electron/shoot.cjs",
    "rebuild": "electron-rebuild -f -w node-pty -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w node-pty -w better-sqlite3 || echo 'native rebuild skipped — run: npm run rebuild'",
    "dist": "vite build && electron-builder",
    "dist:dir": "vite build && electron-builder --dir"
  },
  "build": {
    "appId": "app.kaisola.desktop",
    "productName": "Kaisola",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "michaelofengend",
      "repo": "kaisola"
    },
    "afterPack": "scripts/adhoc-sign.cjs",
    "files": [
      "dist/**",
      "electron/**",
      "!electron/smoke.cjs",
      "!electron/shoot.cjs",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node",
      "node_modules/node-pty/**",
      "node_modules/better-sqlite3/**",
      "node_modules/electron-liquid-glass/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "electron/assets/kaisola-icon.icns",
      "category": "public.app-category.developer-tools",
      "fileAssociations": [
        {
          "ext": [
            "md",
            "markdown",
            "mdx"
          ],
          "name": "Markdown",
          "role": "Editor",
          "rank": "Alternate"
        },
        {
          "ext": [
            "tex",
            "latex",
            "bib"
          ],
          "name": "LaTeX",
          "role": "Editor",
          "rank": "Alternate"
        },
        {
          "ext": [
            "txt",
            "log",
            "json",
            "yaml",
            "yml",
            "csv",
            "py",
            "ts",
            "tsx",
            "js",
            "jsx",
            "css",
            "html",
            "svg"
          ],
          "name": "Text",
          "role": "Editor",
          "rank": "Alternate"
        },
        {
          "ext": [
            "pdf"
          ],
          "name": "PDF",
          "role": "Viewer",
          "rank": "Alternate"
        },
        {
          "ext": [
            "png",
            "jpg",
            "jpeg",
            "gif",
            "webp"
          ],
          "name": "Image",
          "role": "Viewer",
          "rank": "Alternate"
        }
      ]
    },
    "dmg": {
      "title": "Kaisola"
    }
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.3.5",
    "better-sqlite3": "^12.10.0",
    "codemirror": "^6.0.2",
    "electron-liquid-glass": "^1.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.456.0",
    "node-pty": "^1.1.0",
    "openai": "^6.42.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^26.15.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.5"
  }
}
