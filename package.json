{
  "name": "kaisola",
  "productName": "Kaisola",
  "version": "0.1.94",
  "private": true,
  "description": "Kaisola — a Research IDE. Move research from literature → hypotheses → experiments → results → paper, with a human reviewing every transition.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "icon:render": "electron scripts/render-icon.cjs",
    "electron:dev": "concurrently -k \"vite --host 127.0.0.1 --strictPort\" \"wait-on tcp:127.0.0.1:5173 && env -u ELECTRON_RUN_AS_NODE cross-env KAISOLA_DEV_URL=http://127.0.0.1:5173 electron .\"",
    "electron:dev:tools": "concurrently -k \"vite --host 127.0.0.1 --strictPort\" \"wait-on tcp:127.0.0.1:5173 && env -u ELECTRON_RUN_AS_NODE cross-env KAISOLA_DEV_URL=http://127.0.0.1:5173 KAISOLA_OPEN_DEVTOOLS=1 electron .\"",
    "electron": "electron .",
    "smoke": "vite build && env -u ELECTRON_RUN_AS_NODE electron electron/smoke.cjs",
    "broker:probe": "cross-env ELECTRON_RUN_AS_NODE=1 electron electron/session-broker.probe.cjs",
    "companion:probe": "env -u ELECTRON_RUN_AS_NODE electron electron/companion-probe.cjs",
    "companion:pair-harness": "env -u ELECTRON_RUN_AS_NODE cross-env KAISOLA_SMOKE=1 electron electron/companion-pair-harness.cjs",
    "companion:link-probe": "env -u ELECTRON_RUN_AS_NODE electron electron/companion-link-live-probe.cjs",
    "memory:compare": "node electron/memorycompare.cjs",
    "native:resource": "node scripts/native-resource-gate.cjs",
    "native:preflight": "node scripts/native-release-preflight.cjs",
    "native:helper:download": "node scripts/download-native-node-runtime.cjs all",
    "native:helper:probe": "node scripts/native-broker-helper-probe.cjs",
    "shoot": "vite build && electron electron/shoot.cjs",
    "group:probe": "vite build && electron electron/group-ui-probe.cjs",
    "layout:probe": "vite build && electron electron/layout-matrix-probe.cjs",
    "markdown:probe": "vite build && electron electron/markdown-image-probe.cjs",
    "navigation:probe": "vite build && electron electron/perfprobe.cjs NAV",
    "site:probe": "electron electron/site-ui-probe.cjs",
    "rebuild": "electron-rebuild -f -w node-pty -w better-sqlite3",
    "postinstall": "node scripts/postinstall.cjs",
    "dist": "vite build && node scripts/package.cjs",
    "dist:dir": "vite build && electron-builder --dir",
    "release:fast": "node scripts/release-fast.cjs"
  },
  "build": {
    "appId": "app.kaisola.desktop",
    "productName": "Kaisola",
    "protocols": [
      {
        "name": "Kaisola",
        "schemes": [
          "kaisola"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "michaelofengenden",
      "repo": "kaisola"
    },
    "afterPack": "scripts/adhoc-sign.cjs",
    "files": [
      "dist/**",
      "electron/**",
      "!electron/*harness.*",
      "!electron/*probe.*",
      "!electron/*.test.*",
      "!electron/smoke.cjs",
      "!electron/shoot.cjs",
      "!electron/memorycompare.cjs",
      "!electron/memoryAudit.cjs",
      "package.json"
    ],
    "asarUnpack": [
      "electron/session-broker.cjs",
      "electron/ipc/brokerWire.cjs",
      "electron/ipc/sessionBrokerClient.cjs",
      "electron/ipc/securityPolicy.cjs",
      "electron/ipc/terminalManager.cjs",
      "electron/ipc/terminalSpool.cjs",
      "electron/ipc/shellEnv.cjs",
      "**/*.node",
      "node_modules/node-pty/**",
      "node_modules/better-sqlite3/**",
      "node_modules/electron-liquid-glass/**",
      "node_modules/@openai/codex-*/**",
      "node_modules/@anthropic-ai/claude-agent-sdk-*/**"
    ],
    "mac": {
      "minimumSystemVersion": "13.0",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "electron/assets/kaisola-icon.icns",
      "category": "public.app-category.developer-tools",
      "fileAssociations": [
        {
          "ext": [
            "md",
            "markdown",
            "mdx"
          ],
          "name": "Markdown",
          "role": "Editor",
          "rank": "Alternate"
        },
        {
          "ext": [
            "tex",
            "latex",
            "bib"
          ],
          "name": "LaTeX",
          "role": "Editor",
          "rank": "Alternate"
        },
        {
          "ext": [
            "txt",
            "log",
            "json",
            "yaml",
            "yml",
            "csv",
            "py",
            "ts",
            "tsx",
            "js",
            "jsx",
            "css",
            "html",
            "svg"
          ],
          "name": "Text",
          "role": "Editor",
          "rank": "Alternate"
        },
        {
          "ext": [
            "pdf"
          ],
          "name": "PDF",
          "role": "Viewer",
          "rank": "Alternate"
        },
        {
          "ext": [
            "png",
            "jpg",
            "jpeg",
            "gif",
            "webp"
          ],
          "name": "Image",
          "role": "Viewer",
          "rank": "Alternate"
        }
      ]
    },
    "dmg": {
      "title": "Kaisola"
    }
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "0.58.1",
    "@agentclientprotocol/codex-acp": "1.1.2",
    "@anthropic-ai/claude-agent-sdk": "0.3.205",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@modelcontextprotocol/server-sequential-thinking": "2025.12.18",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^12.10.0",
    "electron-liquid-glass": "^1.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.456.0",
    "node-pty": "^1.1.0",
    "openai": "^6.42.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "turndown": "^7.2.4",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@types/node": "^22.9.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.3",
    "cross-env": "^7.0.3",
    "electron": "^39.8.5",
    "electron-builder": "^26.15.3",
    "typescript": "^5.6.3",
    "vite": "^7.3.6",
    "wait-on": "^8.0.5"
  }
}
