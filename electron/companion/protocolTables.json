    "agent.prompt": "agent-control",
    "agent.steer": "agent-control",
    "agent.cancel": "agent-control",
    "permission.respond": "agent-control",
    "terminal.acquire-control": "terminal-control",
    "terminal.renew-control": "terminal-control",
